# Public base URL of the deployed site — used for sitemap, robots and OG/canonical URLs.
# Set this in your host (e.g. Vercel project settings) to your real domain.
NEXT_PUBLIC_SITE_URL=https://velora.example

# ── Velora CMS (/admin) ───────────────────────────────────────────────────
# Copy to .env.local for local dev; set the same in Vercel → Settings →
# Environment Variables for the live site.

# Password for the /admin CMS login. Defaults to "Hammad@123" (baked into the
# code). Set this to override it with a secret that is NOT committed to the repo.
ADMIN_PASSWORD=Hammad@123

# Vercel Blob storage — stores the catalog JSON and uploaded product photos so
# they survive deploys (Vercel's filesystem is read-only). Create a Blob store
# in the Vercel dashboard (Storage → Create → Blob), connect it to this
# project, and Vercel injects this automatically. For local use, run
# `vercel env pull .env.local`. If unset, the CMS falls back to the local
# filesystem (dev only).
BLOB_READ_WRITE_TOKEN=
